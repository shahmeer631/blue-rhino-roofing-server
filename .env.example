PORT=5000
# Local dev: default below is fine. On Railway/production: set MONGODB_URI to MongoDB Atlas (mongodb+srv://...).
# Atlas: https://www.mongodb.com/cloud/atlas → Create cluster → Connect → Drivers → copy URI, replace <password>.
MONGODB_URI=mongodb://localhost:27017/blue-rhino-roofing
# Required for the chatbot. On Railway: Project → Variables → add OPENAI_API_KEY (exact name).
OPENAI_API_KEY=your_openai_api_key_here
CLIENT_URL=http://localhost:5173
NODE_ENV=development

# Gmail SMTP — MUST be a Google "App Password" (16 characters), not your normal login password.
# Create it: https://myaccount.google.com/apppasswords (requires 2-Step Verification on that account first)
#
# Google Workspace (e.g. Help@yourdomain.com): same flow while signed in as that mailbox; your admin must
# allow 2-Step Verification. Never paste a SendGrid/old API key here — you will get "535 Authentication failed".
SMTP_USER=yourname@gmail.com
SMTP_PASS=abcdabcdabcdabcd

# Optional: defaults to SMTP_USER. Must be allowed for that Gmail account (or a configured alias).
# SMTP_FROM_EMAIL=yourname@gmail.com

# Display name shown in the recipient's inbox (reduces spam-like "unknown sender" look).
# SMTP_FROM_NAME=Blue Rhino Roofing

# Where lead notifications are delivered (your Gmail or team inbox)
LEAD_NOTIFICATION_EMAIL=Help@BlueRhinoRoofing.net

# Send a thank-you email to the visitor's address from the form (default on). Set false to disable.
# SEND_CUSTOMER_LEAD_CONFIRMATION=false
